# Ultraclaw Configuration
# Copy this file to .env and fill in your values.

# --- Matrix Configuration (Required) ---
ULTRACLAW_MATRIX_USER=@your_username:matrix.org
ULTRACLAW_MATRIX_PASSWORD=your_password
# ULTRACLAW_MATRIX_HOMESERVER=https://matrix.org  # Optional if using matrix.org

# --- General Settings ---
# ULTRACLAW_LOG_LEVEL=info  # debug, info, warn, error
# ULTRACLAW_DB_PATH=ultraclaw.db
# ULTRACLAW_MEDIA_OUTPUT_DIR=media_output
# ULTRACLAW_HEADLESS=false  # Set to true to run without GUI (if applicable)

# --- Media Generation Preferences ---
# Preferred providers override defaults but fallback if unavailable/key missing.
# Options: openai, stability, replicate, together, fal, leonardo, imagen, veo, kling, seedance, luma, minimax, pika, sora
# ULTRACLAW_PREFERRED_IMAGE_PROVIDER=openai
# ULTRACLAW_PREFERRED_VIDEO_PROVIDER=runway

# --- API Keys (Uncomment and fill to enable providers) ---

# Image & Text
# ULTRACLAW_CLOUD_API_KEY=sk-...          # OpenAI (DALL-E 3, GPT-4)
# ULTRACLAW_STABILITY_API_KEY=sk-...      # Stability AI (SDXL, SD3)
# ULTRACLAW_TOGETHER_API_KEY=...          # Together AI (FLUX)
# ULTRACLAW_FAL_API_KEY=...               # Fal.ai (FLUX, Minimax, etc.)
# ULTRACLAW_REPLICATE_API_KEY=r8_...      # Replicate (FLUX, Video)
# ULTRACLAW_LEONARDO_API_KEY=...          # Leonardo AI
# ULTRACLAW_IMAGEN_API_KEY=AIzr...        # Google Imagen

# Video
# ULTRACLAW_RUNWAY_API_KEY=...            # Runway ML (Gen-3 Alpha)
# ULTRACLAW_VEO_API_KEY=...               # Google Veo
# ULTRACLAW_KLING_API_KEY=...             # Kling
# ULTRACLAW_SEEDANCE_API_KEY=...          # Seedance (ByteDance) - or use Fal key
# ULTRACLAW_LUMA_API_KEY=...              # Luma Dream Machine
# ULTRACLAW_MINIMAX_API_KEY=...           # Minimax / Hailuo
# ULTRACLAW_PIKA_API_KEY=...              # Pika - or use Fal key
# ULTRACLAW_SORA_API_KEY=...              # OpenAI Sora - or use OpenAI key
